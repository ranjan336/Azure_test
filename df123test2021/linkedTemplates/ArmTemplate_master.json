{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "df123test2021"
		},
		"ls_blobpopul_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'ls_blobpopul'"
		},
		"ls_popdl_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ls_popdl'"
		},
		"ls_ecdedata_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "@{linkedService().burl}"
		},
		"ls_popdl_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://covidsadl1.dfs.core.windows.net"
		},
		"tr_ecdc_file_ingest_properties_pl_ecdc_data_parameters_surl": {
			"type": "string",
			"defaultValue": "covid19/blob/main/raw/main/ecdc_data/cases_deaths.csv"
		},
		"tr_ecdc_file_ingest_properties_pl_ecdc_data_parameters_sfilename": {
			"type": "string",
			"defaultValue": "cases_death.csv"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "df123test2021_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2018-02-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ls_blobpopul_connectionString": {
						"value": "[parameters('ls_blobpopul_connectionString')]"
					},
					"ls_popdl_accountKey": {
						"value": "[parameters('ls_popdl_accountKey')]"
					},
					"ls_ecdedata_properties_typeProperties_url": {
						"value": "[parameters('ls_ecdedata_properties_typeProperties_url')]"
					},
					"ls_popdl_properties_typeProperties_url": {
						"value": "[parameters('ls_popdl_properties_typeProperties_url')]"
					},
					"tr_ecdc_file_ingest_properties_pl_ecdc_data_parameters_surl": {
						"value": "[parameters('tr_ecdc_file_ingest_properties_pl_ecdc_data_parameters_surl')]"
					},
					"tr_ecdc_file_ingest_properties_pl_ecdc_data_parameters_sfilename": {
						"value": "[parameters('tr_ecdc_file_ingest_properties_pl_ecdc_data_parameters_sfilename')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}